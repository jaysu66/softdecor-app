# ═══════════════════════════════════════════════════════════════
#  LLM 配置（任意 OpenAI 兼容的 /v1/chat/completions 服务都行）
# ═══════════════════════════════════════════════════════════════
# 代码里所有的文本/视觉 AI 调用都走 OpenAI 标准格式。
# 你可以对接 OpenAI、OpenRouter、Azure OpenAI、Anthropic、Gemini、
# Ollama、LM Studio、vLLM、or 任何自建兼容网关。
#
# 详见 README 里的「配置 LLM 提供方」小节。

# —— 基础配置 ——
LLM_BASE_URL=https://api.openai.com/v1/chat/completions
LLM_API_KEY=sk-your-openai-key-here

# —— 模型选择 ——
# LLM_VISION_MODEL: 用于房间分析、场景 prompt 生成、精修反馈
#                   需要支持 vision（读图）和 JSON 输出
#                   推荐: gpt-4o / claude-3-5-sonnet / gemini-2.0-flash
LLM_VISION_MODEL=gpt-4o

# LLM_AGENT_MODEL: 用于画布 Agent 的 tool-use
#                  需要支持 function calling
#                  推荐: gpt-4o / gpt-4o-mini / claude-3-5-sonnet
LLM_AGENT_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════════
#  火山引擎 ARK API (Seedream 5.0 / 3.0) - 图像生成
# ═══════════════════════════════════════════════════════════════
# 这是必须的，所有场景合成都走 Seedream。
# 在火山引擎控制台申请 API Key: https://www.volcengine.com/product/ark

ARK_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/images/generations
ARK_BASE=https://ark.cn-beijing.volces.com/api/v3
ARK_KEY=your-volcano-ark-key-here

# ═══════════════════════════════════════════════════════════════
#  数据目录（可选）
# ═══════════════════════════════════════════════════════════════
# 默认读取项目内的 assets/ 目录；如需指向外部路径，取消注释并用绝对路径覆盖
# DATA_DIR=/absolute/path/to/softdecor-ai-images


# ───────────────────────────────────────────────────────────────
#  常见 LLM 提供方配置示例（复制到上面 LLM_BASE_URL 区域即可）
# ───────────────────────────────────────────────────────────────

# ── OpenAI (默认) ──
# LLM_BASE_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_VISION_MODEL=gpt-4o
# LLM_AGENT_MODEL=gpt-4o

# ── OpenRouter（一个 key 调所有模型，推荐） ──
# LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
# LLM_API_KEY=sk-or-v1-...
# LLM_VISION_MODEL=anthropic/claude-3.5-sonnet
# LLM_AGENT_MODEL=openai/gpt-4o

# ── Azure OpenAI ──
# LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/deployments/YOUR-DEPLOYMENT/chat/completions?api-version=2024-10-21
# LLM_API_KEY=your-azure-key
# LLM_VISION_MODEL=gpt-4o
# LLM_AGENT_MODEL=gpt-4o

# ── Anthropic（通过 OpenAI 兼容端点）──
# LLM_BASE_URL=https://api.anthropic.com/v1/chat/completions
# LLM_API_KEY=sk-ant-...
# LLM_VISION_MODEL=claude-3-5-sonnet-latest
# LLM_AGENT_MODEL=claude-3-5-sonnet-latest

# ── Google Gemini（通过 OpenAI 兼容端点）──
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
# LLM_API_KEY=your-google-api-key
# LLM_VISION_MODEL=gemini-2.0-flash
# LLM_AGENT_MODEL=gemini-2.0-flash

# ── 阿里云百炼（DashScope）──
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_VISION_MODEL=qwen-vl-max
# LLM_AGENT_MODEL=qwen-max

# ── DeepSeek ──（注：DeepSeek 目前不支持 vision，房间分析会失效）
# LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_AGENT_MODEL=deepseek-chat

# ── 硅基流动 SiliconFlow ──
# LLM_BASE_URL=https://api.siliconflow.cn/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_VISION_MODEL=Qwen/Qwen2-VL-72B-Instruct
# LLM_AGENT_MODEL=Qwen/Qwen2.5-72B-Instruct

# ── Ollama（本地）──
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# LLM_API_KEY=ollama
# LLM_VISION_MODEL=llava
# LLM_AGENT_MODEL=llama3.1

# ── LM Studio（本地）──
# LLM_BASE_URL=http://localhost:1234/v1/chat/completions
# LLM_API_KEY=lm-studio
# LLM_VISION_MODEL=your-loaded-model-id
# LLM_AGENT_MODEL=your-loaded-model-id
